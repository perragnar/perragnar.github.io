<script>
carouselItemData = {{ site.data.carousel | where: "active", "true" | jsonify }};
const carouselItems = carouselItemData ? carouselItemData : [];
</script>

<header id="page-header" class="page-header page-header--full section">
    <nav class="page-navigation">
        <ul class="navigation-list">
            {% for link in site.data.navigation %}
                <li class="{{ link.cssClass }}{% if page.url == link.url %} active{% endif %}">
                    <a href="{{ link.url }}">
                        {{ link.title }}
                        {{ link.content }}
                    </a>
                </li>
            {% endfor %}
        </ul>
    </nav>
    {% include carousel.liquid %}
</header>
