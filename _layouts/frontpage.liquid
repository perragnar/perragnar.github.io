---
layout: default
---

{% if site.site_open and page.page_open != false  %}
    <main class="page">
        <section class="intro section">
            <div class="section__content">
                <h1 class="page-title">Hej!</h1>
                <p>
                    Per Ragnar Edin heter jag och är hobbyfotograf.
                </p>
                <p>
                    Lorem ipsum dolor sit amet, consectetur adipisicing elit. Dicta laboriosam inventore quisquam dolore unde consequuntur temporibus a omnis voluptate, hic doloribus quidem deleniti aliquam reprehenderit laborum ducimus modi iure neque.
                </p>
                <img data-src="/assets/img/sign-black.png" alt="Per Ragnar Edin" width="400" class="signature lazyload">
            </div>
        </section>
        <section class="photo section">
            <div class="section__content">
                <h2 class="section-title">Fotografering</h2>
                <p>
                    Det jag fotograferar allra helst är landskap och natur, men jag gillar utmaningar och att lära mig mer om fotografering och bildbehandling.
                </p>
                <p>
                    Det bästa med landskaps- och naturfotografering är att ta sig ut i naturen och meditera!
                </p>
                <div class="button-container">
                    <button class="button">Bloggen</button>
                    <button class="button">Prints</button>
                </div>
            </div>
            <div class="gallery-categories">
                <a href="#" class="category">
                    <img data-src="/assets/img/photos/categories/landscape-1.jpg" class="lazyload category__image">
                    <h3 class="category__title">Landskap – vyer</h3>
                </a>
                <a href="#" class="category">
                    <img data-src="/assets/img/photos/categories/landscape-2.jpg" class="lazyload category__image">
                    <h3 class="category__title">Landskap – intimt</h3>
                </a>
                <a href="#" class="category">
                    <img data-src="/assets/img/photos/categories/portraits-3.jpg" class="lazyload category__image">
                    <h3 class="category__title">Människor / Porträtt</h3>
                </a>
                <a href="#" class="category">
                    <img data-src="/assets/img/photos/categories/portraits-1.jpg" class="lazyload category__image">
                    <h3 class="category__title">Landskap – vyer</h3>
                </a>
                <a href="#" class="category">
                    <img data-src="/assets/img/photos/categories/portraits-2.jpg" class="lazyload category__image">
                    <h3 class="category__title">Landskap – intimt</h3>
                </a>
            </div>
        </section>
        <section class="contact section">
            <div class="section__content">
                <div class="contact__intro">
                    <h2 class="section-title">Kontakt</h2>
                    <p>
                        Undrar du något så kan du kontakta mig på mail, Instagram eller Facebook.
                    </p>
                    <p>
                        <span class="decorated">Vill du köpa en bild – digital eller print?</span>
                    </p>
                </div>
                <div class="fb fb--responsive fb--align-center">
                    <figure class="contact-photo fi--1">
                        <img data-src="/assets/img/about-1.jpg" alt="Per Ragnar Edin" class="lazyload">
                    </figure>
                    <div class="fb fb--center fi--1">
                        <ul class="contact-options fb fb--column">
                            <li><button class="button button--contact button--instagram" data-href="https://instagram.com/perragnarfoto"><span>Instagram</span></button></li>
                            <li><button class="button button--contact button--facebook" data-href="https://facebook.com/perragnarfoto"><span>Facebook</span></button></li>
                            <li><button class="button button--contact button--email" data-href="mailto:perragnar.foto@gmail.com"><span>E-post</span></button></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="section__photo lazyload" data-bg="/assets/img/about-bg.jpg"></div>
        </section>
    </main>



    {% comment %} <section class="section section--default">
        <div class="slice">
            <div class="row">
                <div class="col col--full card card--ghost">
                    <div class="card__body">
                        {{ content }}
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="section section--photo">
        <div class="slice">
            <div class="row">
                <div class="col col--full card card--ghost">
                    <div class="card__body">
                        <h2 class="section__header"><a href="photo">Fotobloggen</a></h2>
                        <p>
                            I fotobloggen lägger jag upp inlägg med foton. Här är de sex senaste inläggen.
                        </p>
                    </div>
                </div>
            </div>
            <div class="row">
                {% assign photo_posts = site.posts | where: "categories", "Fotoblogg" | where_exp: "post", "post.draft != true" %}
                {% for post in photo_posts limit: 6 %}
                    {% assign post_categories = post.categories | downcase %}
                        {% unless post.draft %}
                            <div class="col col--1-3 card card--dark">
                                <div class="card__poster">
                                    <div class="card__date--poster">{% include datetime.liquid datetime=post.date %}</div>
                                    <div class="card__meta">
                                        <h3 class="card__title">
                                            {{ post.title }}
                                        </h3>
                                        <div class="post-meta">
                                            {% if post.tags %}
                                                <div class="post-meta-section tags">
                                                    <ul>
                                                        {% for tag in post.tags %}
                                                            <li><a href="/tags/#{{ tag | slugify: 'pretty' }}" class="tag">{{ tag }}</a></li>
                                                        {% endfor %}
                                                    </ul>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <a href="{{ post.url }}">
                                        {% assign posterMode = '' %}

                                        {% if post.galleries %}
                                            {% assign posterMode = 'galleryfile' %}
                                        {% endif %}

                                        {% if post.poster %}
                                            {% assign posterMode = 'posterfile' %}
                                        {% endif %}

                                        {% if posterMode == 'galleryfile' %}
                                            {% for gallerySlug in post.galleries %}
                                                {% assign gallery = site.data.galleries[gallerySlug] %}
                                                {% if gallery.contents %}
                                                    {% assign photos = gallery.contents %}
                                                    {% if gallery.poster %}
                                                        <div class="photo" style="background-image: url(/assets/photos/galleries/{{ gallerySlug }}/{{ gallery.poster }});"></div>
                                                    {% else %}
                                                        {% for photo in photos limit:1 %}
                                                            <div class="photo" style="background-image: url(/assets/photos/galleries/{{ gallerySlug }}/{{ photo.filename }});"></div>
                                                        {% endfor %}
                                                    {% endif %}
                                                {% endif %}
                                            {% endfor %}
                                        {% elsif posterMode == 'posterfile' %}
                                            {% if post.poster contains '://' %}
                                                {% assign poster_url = post.poster %}
                                            {% else %}
                                                {% assign poster_url = post.poster | prepend: site.baseurl | prepend: '/assets/posters/' %}
                                            {% endif %}
                                            <div class="photo" style="background-image: url({{ poster_url }});"></div>
                                        {% else %}
                                            <div class="photo faded" style="background-image: url(/assets/img/photo-blog-default-poster.jpg);"></div>
                                        {% endif %}
                                    </a>
                                </div>
                            </div>
                        {% endunless %}
                {% endfor %}
            </div>
            <div class="row">
                <div class="col col--full card card--ghost">
                    <div class="card__body align-center">
                        <a href="/photo" class="button button--large button--rogue button--rounded">Till fotobloggen</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
    {% comment %} <section class="section section--blog">
        <div class="slice">
            <div class="row">
                <div class="col col--full card card--ghost">
                    <div class="card__body align-center">
                        <h3 class="section__header">Senaste blogginläggen</h3>
                        {% include timeline-section.liquid limit=10 %}
                    </div>
                </div>
            </div>
        </div>
    </section> {% endcomment %}
    <section class="section section--default">
        <div class="slice">
            <div class="row">
                <div class="col col--full card card--ghost">
                    <div class="card__body">
                        <h3 class="section__header">Oh, btw...</h3>
                        <p>
                            Do you code? Using
                            <a href="https://code.visualstudio.com" target="_blank">Visual Studio Code</a>?
                            <br> I've made a couple of themes. Go grab them at
                            <a href="https://marketplace.visualstudio.com/search?term=publisher%3A%22Per%20Ragnar%20Edin%22&target=VSCode&category=All%20categories&sortBy=Relevance"
                                target="_blank">Visual Studio Marketplace</a>. Here's
                            <strong>September Steel</strong> and
                            <strong>Light+ Tweaked</strong>.
                        </p>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col col--1-2 card card--ghost">
                    <div class="card__body align-center">
                        <h4>September Steel</h4>
                        <a href="https://marketplace.visualstudio.com/items?itemName=perragnaredin.september-steel" target="_blank" class="silent">
                            <img src="https://raw.githubusercontent.com/perragnar/september-steel/master/images/screenshots/syntax-javascript.png" loading="lazy" alt="September Steel">
                        </a>
                        <a class="github-button" href="https://github.com/perragnar/september-steel" data-size="large" data-show-count="true" aria-label="Star perragnar/september-steel on GitHub">Star</a>
                    </div>
                </div>
                <div class="col col--1-2 card card--ghost">
                    <div class="card__body align-center">
                        <h4>Default+ Tweaked</h4>
                        <a href="https://marketplace.visualstudio.com/items?itemName=perragnaredin.light-plus-tweaked" target="_blank" class="silent">
                            <img src="https://raw.githubusercontent.com/perragnar/light-plus-tweaked/master/images/screenshots/screenshot-light.png" loading="lazy" alt="Default+ Tweaked">
                        </a>
                        <a class="github-button" href="https://github.com/perragnar/light-plus-tweaked" data-size="large" data-show-count="true" aria-label="Star perragnar/light-plus-tweaked on GitHub">Star</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <script async defer src="https://buttons.github.io/buttons.js"></script> {% endcomment %}
{% endif %}
